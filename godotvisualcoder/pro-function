<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GDScript Pro Generator</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#080b0f;--bg2:#0d1117;--bg3:#141b22;--bg4:#1c2430;--bg5:#232d3a;
  --border:#1e2a38;--border2:#253040;--border3:#2e3d50;
  --text:#d4dde8;--text2:#7f96b0;--text3:#4a5f72;--text4:#2e3d50;
  --green:#39d353;--green2:#2ea043;--green-dim:rgba(57,211,83,0.08);
  --blue:#58a6ff;--blue-dim:rgba(88,166,255,0.08);
  --purple:#bc8cff;--purple-dim:rgba(188,140,255,0.08);
  --amber:#e3b341;--amber-dim:rgba(227,179,65,0.08);
  --red:#f85149;--red-dim:rgba(248,81,73,0.08);
  --cyan:#76e3ea;--cyan-dim:rgba(118,227,234,0.08);
  --orange:#ffa657;
  --r:8px;--r2:12px;
}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.5}

/* ══════════════════════ SCROLLBARS ══════════════════════ */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border3);border-radius:3px}

/* ══════════════════════ HEADER ══════════════════════ */
.header{
  display:flex;align-items:center;gap:16px;
  padding:0 20px;height:52px;
  background:var(--bg2);border-bottom:1px solid var(--border2);
  position:fixed;top:0;left:0;right:0;z-index:200;
}
.logo{font-size:15px;font-weight:700;color:var(--green);letter-spacing:-0.5px}
.logo span{color:var(--text3)}
.header-sep{color:var(--text4);font-size:10px}
.header-desc{color:var(--text3);font-size:11px}
.header-pills{display:flex;gap:6px;margin-left:auto}
.pill{padding:3px 10px;border-radius:20px;font-size:10px;font-weight:600;letter-spacing:0.5px;border:1px solid}
.pill-green{color:var(--green);border-color:rgba(57,211,83,0.3);background:var(--green-dim)}
.pill-blue{color:var(--blue);border-color:rgba(88,166,255,0.3);background:var(--blue-dim)}

/* ══════════════════════ LAYOUT ══════════════════════ */
.workspace{
  display:grid;grid-template-columns:1fr 1fr;
  height:calc(100vh - 52px);margin-top:52px;
  overflow:hidden;
}
.left-panel{
  display:flex;flex-direction:column;
  border-right:1px solid var(--border2);
  overflow:hidden;
}
.right-panel{display:flex;flex-direction:column;overflow:hidden}

/* ══════════════════════ SECTIONS ══════════════════════ */
.sec{border-bottom:1px solid var(--border);flex-shrink:0}
.sec-hdr{
  display:flex;align-items:center;gap:8px;
  padding:8px 14px;cursor:pointer;user-select:none;
  font-size:11px;font-weight:600;color:var(--text3);
  text-transform:uppercase;letter-spacing:0.8px;
  transition:color 0.15s;
}
.sec-hdr:hover{color:var(--text2)}
.sec-hdr .arrow{margin-left:auto;font-size:9px;transition:transform 0.2s}
.sec-hdr.open .arrow{transform:rotate(90deg)}
.sec-body{display:none;padding:12px 14px;gap:10px;flex-direction:column}
.sec-body.open{display:flex}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* ══════════════════════ FUNC TABS ══════════════════════ */
.func-tab-bar{
  display:flex;align-items:center;gap:0;
  background:var(--bg2);border-bottom:1px solid var(--border2);
  overflow-x:auto;flex-shrink:0;min-height:40px;
}
.func-tab{
  display:flex;align-items:center;gap:6px;
  padding:0 12px;height:40px;flex-shrink:0;
  font-size:11px;cursor:pointer;color:var(--text3);
  border-right:1px solid var(--border);
  transition:all 0.15s;white-space:nowrap;
  border-bottom:2px solid transparent;
}
.func-tab:hover{color:var(--text2);background:var(--bg3)}
.func-tab.active{
  color:var(--blue);background:var(--bg3);
  border-bottom-color:var(--blue);
}
.func-tab .tab-del{
  color:var(--text4);font-size:14px;line-height:1;
  padding:0 2px;border-radius:3px;
}
.func-tab .tab-del:hover{color:var(--red);background:var(--red-dim)}
.add-func-btn{
  display:flex;align-items:center;gap:5px;
  padding:0 14px;height:40px;flex-shrink:0;
  font-size:11px;font-family:inherit;
  background:none;border:none;color:var(--text3);cursor:pointer;
}
.add-func-btn:hover{color:var(--green)}

/* ══════════════════════ FUNC EDITOR ══════════════════════ */
.func-editor{
  flex:1;overflow-y:auto;
  display:flex;flex-direction:column;gap:0;
}

/* ══════════════════════ FORMS ══════════════════════ */
.row2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.field{display:flex;flex-direction:column;gap:4px}
.field-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.6px}

input,select,textarea{
  background:var(--bg4);
  border:1px solid var(--border2);
  border-radius:var(--r);
  padding:7px 10px;
  color:var(--text);
  font-family:'JetBrains Mono',monospace;
  font-size:12px;
  outline:none;
  transition:border-color 0.15s;
  width:100%;
}
input:focus,select:focus,textarea:focus{border-color:var(--border3)}
input::placeholder,textarea::placeholder{color:var(--text4)}
select option{background:var(--bg4)}

/* ══════════════════════ CHECKBOXES ══════════════════════ */
.toggle-row{display:flex;gap:16px;flex-wrap:wrap}
.toggle{
  display:flex;align-items:center;gap:7px;
  cursor:pointer;padding:6px 10px;border-radius:var(--r);
  border:1px solid var(--border);font-size:11px;color:var(--text2);
  transition:all 0.15s;
}
.toggle:hover{border-color:var(--border3)}
.toggle.active{border-color:rgba(88,166,255,0.4);background:var(--blue-dim);color:var(--blue)}
.toggle input{display:none}

/* ══════════════════════ PARAMS ══════════════════════ */
.param-list{display:flex;flex-direction:column;gap:6px}
.param-item{
  display:flex;align-items:center;gap:6px;
  background:var(--bg4);border:1px solid var(--border);
  border-radius:var(--r);padding:6px 8px;
}
.param-item input,
.param-item select{flex:1;min-width:60px;padding:5px 8px;font-size:11px}
.param-item .param-del{
  background:none;border:none;color:var(--text4);
  cursor:pointer;font-size:16px;padding:0 4px;flex-shrink:0;
}
.param-item .param-del:hover{color:var(--red)}

/* ══════════════════════ ACTIONS ══════════════════════ */
.action-list{
  display:flex;flex-direction:column;gap:4px;
  min-height:50px;
}
.action-row{
  display:flex;align-items:flex-start;gap:5px;
  background:var(--bg4);border:1px solid var(--border);
  border-radius:var(--r);padding:5px 6px;
  position:relative;transition:border-color 0.15s;
}
.action-row:hover{border-color:var(--border3)}

/* Indent color coding */
.action-row[data-indent="0"] .indent-strip{background:var(--text4)}
.action-row[data-indent="1"] .indent-strip{background:var(--blue);opacity:0.5}
.action-row[data-indent="2"] .indent-strip{background:var(--purple);opacity:0.5}
.action-row[data-indent="3"] .indent-strip{background:var(--green);opacity:0.5}
.action-row[data-indent="4"] .indent-strip{background:var(--amber);opacity:0.5}

.indent-strip{
  width:3px;border-radius:2px;flex-shrink:0;
  align-self:stretch;min-height:22px;
}
.action-move{
  display:flex;flex-direction:column;gap:0;flex-shrink:0;
}
.action-move button{
  background:none;border:none;color:var(--text4);
  cursor:pointer;font-size:10px;padding:1px 3px;line-height:1;
  font-family:inherit;
}
.action-move button:hover{color:var(--text2)}

.action-type-sel{
  width:120px;flex-shrink:0;
  padding:4px 6px;font-size:11px;
}
.indent-ctrl{
  display:flex;align-items:center;gap:3px;flex-shrink:0;
}
.indent-ctrl button{
  background:var(--bg3);border:1px solid var(--border2);
  color:var(--text3);cursor:pointer;
  width:18px;height:22px;font-size:10px;
  border-radius:3px;font-family:inherit;
  display:flex;align-items:center;justify-content:center;
}
.indent-ctrl button:hover{color:var(--text);border-color:var(--border3)}
.indent-val{
  width:20px;text-align:center;font-size:11px;
  color:var(--text2);line-height:22px;flex-shrink:0;
}
.action-fields{
  flex:1;display:flex;gap:5px;flex-wrap:wrap;min-width:0;
}
.action-fields input,
.action-fields select{
  flex:1;min-width:80px;
  padding:4px 7px;font-size:11px;
}
.action-fields .raw-input{
  flex:1;min-width:200px;
  font-size:11px;padding:4px 7px;
  background:var(--bg3);border-color:rgba(57,211,83,0.2);
  color:var(--green);
}
.action-fields .comment-input{
  flex:1;font-size:11px;padding:4px 7px;
  background:var(--bg3);border-color:rgba(74,95,114,0.3);
  color:var(--text3);
}
.action-del{
  background:none;border:none;color:var(--text4);
  cursor:pointer;font-size:15px;padding:0 4px;
  flex-shrink:0;line-height:22px;
}
.action-del:hover{color:var(--red)}

/* ══════════════════════ ADD BUTTONS ══════════════════════ */
.add-btn{
  width:100%;padding:8px;
  background:var(--bg3);border:1px dashed var(--border3);
  border-radius:var(--r);color:var(--text3);
  font-size:11px;font-family:inherit;cursor:pointer;
  transition:all 0.15s;
}
.add-btn:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-dim)}
.add-btn.green:hover{border-color:var(--green);color:var(--green);background:var(--green-dim)}

/* ══════════════════════ TEMPLATES ══════════════════════ */
.tmpl-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(130px,1fr));
  gap:6px;
}
.tmpl-btn{
  padding:7px 8px;background:var(--bg4);
  border:1px solid var(--border);border-radius:var(--r);
  font-size:10px;font-family:inherit;cursor:pointer;
  color:var(--text2);text-align:left;line-height:1.4;
  transition:all 0.15s;
}
.tmpl-btn:hover{border-color:var(--border3);background:var(--bg5);color:var(--text)}
.tmpl-btn span{display:block;font-size:16px;margin-bottom:2px}

/* ══════════════════════ BOTTOM BAR ══════════════════════ */
.bottom-bar{
  padding:12px 14px;border-top:1px solid var(--border2);
  display:flex;gap:8px;flex-shrink:0;background:var(--bg2);
}
.btn{
  flex:1;padding:10px 16px;border:none;border-radius:var(--r);
  font-size:12px;font-weight:700;font-family:inherit;
  cursor:pointer;transition:all 0.15s;
}
.btn-primary{
  background:linear-gradient(135deg,#238636,#196c2e);
  color:white;
}
.btn-primary:hover{background:linear-gradient(135deg,#2ea043,#238636)}
.btn-primary:active{transform:scale(0.98)}
.btn-sm{
  padding:7px 12px;font-size:11px;
  background:var(--bg4);border:1px solid var(--border2);
  border-radius:var(--r);color:var(--text2);
  font-family:inherit;cursor:pointer;
}
.btn-sm:hover{border-color:var(--border3);color:var(--text)}

/* ══════════════════════ OUTPUT PANEL ══════════════════════ */
.output-header{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;border-bottom:1px solid var(--border2);
  background:var(--bg2);flex-shrink:0;
}
.output-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px}
.output-actions{display:flex;gap:6px;margin-left:auto}
.copy-btn{
  padding:5px 12px;background:var(--bg4);
  border:1px solid var(--border2);border-radius:var(--r);
  color:var(--text2);font-size:10px;font-family:inherit;cursor:pointer;
  transition:all 0.15s;
}
.copy-btn:hover{border-color:var(--green);color:var(--green)}
.copy-btn.ok{background:var(--green-dim);border-color:var(--green);color:var(--green)}

.output-code{
  flex:1;overflow-y:auto;
  padding:16px;
  font-size:12.5px;line-height:1.75;
  white-space:pre;
  font-family:'JetBrains Mono',monospace;
  tab-size:4;
}

/* ══════════════════════ SYNTAX HIGHLIGHTING ══════════════════════ */
.kw{color:var(--red)}
.kw2{color:var(--purple)}
.fn{color:var(--blue)}
.ty{color:var(--cyan)}
.str{color:var(--amber)}
.num{color:var(--orange)}
.cmt{color:var(--text3);font-style:italic}
.ann{color:var(--purple)}
.op{color:var(--text2)}

/* ══════════════════════ CLASS VARS ══════════════════════ */
.cvar-item{
  display:flex;align-items:center;gap:6px;
  background:var(--bg4);border:1px solid var(--border);
  border-radius:var(--r);padding:5px 8px;
}
.cvar-ann{
  width:100px;flex-shrink:0;padding:4px 6px;font-size:11px;
}
.cvar-name,.cvar-type,.cvar-val{
  flex:1;min-width:60px;padding:4px 7px;font-size:11px;
}
.cvar-del{
  background:none;border:none;color:var(--text4);
  cursor:pointer;font-size:14px;padding:0 3px;
}
.cvar-del:hover{color:var(--red)}

/* ══════════════════════ SCROLLABLE AREAS ══════════════════════ */
.scrollable{overflow-y:auto;flex:1}
.func-editor .sec{flex-shrink:0}

/* ══════════════════════ STATUS BAR ══════════════════════ */
.status-bar{
  display:flex;align-items:center;gap:10px;
  padding:4px 14px;border-top:1px solid var(--border);
  font-size:10px;color:var(--text3);flex-shrink:0;
  background:var(--bg2);
}
.status-item{display:flex;align-items:center;gap:5px}
.status-dot{width:5px;height:5px;border-radius:50%;background:var(--green)}

/* ══════════════════════ IMPORT ══════════════════════ */
.import-zone{
  padding:12px;border:1px dashed var(--border3);
  border-radius:var(--r);cursor:pointer;
  font-size:11px;color:var(--text3);text-align:center;
  transition:all 0.15s;
}
.import-zone:hover{border-color:var(--blue);color:var(--blue);background:var(--blue-dim)}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════ HEADER ═══════════════════════════════════════ -->
<div class="header">
  <div class="logo">GDS<span>cript</span>PRO</div>
  <div class="header-sep">▸</div>
  <div class="header-desc">Universal Function Generator · Extended Blocks</div>
  <div class="header-pills">
    <span class="pill pill-green">INDENT AWARE</span>
    <span class="pill pill-blue">MULTI-FUNCTION BLOCKS</span>
  </div>
</div>

<!-- ═══════════════════════════════════════ WORKSPACE ═══════════════════════════════════════ -->
<div class="workspace">

  <!-- ══════════════════ LEFT ══════════════════ -->
  <div class="left-panel">

    <!-- Class Variables -->
    <div class="sec">
      <div class="sec-hdr" onclick="toggleSec(this)">
        <div class="dot" style="background:var(--amber)"></div>
        Class-Level Declarations
        <span class="arrow">▶</span>
      </div>
      <div class="sec-body">
        <div id="cvarList" class="param-list"></div>
        <button class="add-btn" onclick="addClassVar()">+ Add @export / @onready / signal / var</button>
      </div>
    </div>

    <!-- Function Tabs -->
    <div class="func-tab-bar" id="funcTabBar">
      <button class="add-func-btn" onclick="addFunction()">＋ Add Function</button>
    </div>

    <!-- Function Editor (scrollable) -->
    <div class="func-editor scrollable" id="funcEditor">
      <div class="empty-hint" style="margin:20px">
        Click <strong>＋ Add Function</strong> to start building,<br>
        or load a <strong>template</strong> from the panel below.
      </div>
    </div>

    <!-- Templates -->
    <div class="sec">
      <div class="sec-hdr" onclick="toggleSec(this)">
        <div class="dot" style="background:var(--cyan)"></div>
        Templates
        <span class="arrow">▶</span>
      </div>
      <div class="sec-body">
        <div class="tmpl-grid" id="tmplGrid"></div>
      </div>
    </div>

    <!-- Bottom Buttons -->
    <div class="bottom-bar">
      <button class="btn btn-primary" onclick="generateAll()">⚡ Generate All Code</button>
    </div>

    <!-- Status -->
    <div class="status-bar">
      <div class="status-item"><div class="status-dot"></div><span id="statusText">Ready</span></div>
      <span id="funcCount" style="margin-left:auto">0 functions · 0 actions</span>
    </div>
  </div>

  <!-- ══════════════════ RIGHT ══════════════════ -->
  <div class="right-panel">
    <div class="output-header">
      <span class="output-title">⬡ Generated GDScript</span>
      <div class="output-actions">
        <button class="btn-sm" onclick="exportJSON()">↓ Export JSON</button>
        <label class="btn-sm" style="cursor:pointer" for="importFile">↑ Import JSON</label>
        <input type="file" id="importFile" accept=".json" style="display:none" onchange="importJSON(this)">
        <button class="copy-btn" id="copyBtn" onclick="copyCode()">Copy All</button>
      </div>
    </div>
    <div class="output-code" id="outputCode"><span class="cmt"># Click ⚡ Generate All Code to build your GDScript
# or load a template from the left panel

# ─── HOW THE INDENT SYSTEM WORKS ─────────────────────────────
# Each action has an explicit indent level [◀ N ▶]
# 0 = first level inside function body
# 1 = inside if/for/match block
# 2 = nested block
# Use "raw" action type for any complex expression
# ─────────────────────────────────────────────────────────────</span></div>
  </div>
</div>

<script>
'use strict';

// ══════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════
let classVars = [];
let functions  = [];   // { id, name, returnType, isStatic, rpcMode, params[], actions[] }
let activeFnId = null;
let _nextId    = 1;
const uid = () => _nextId++;

// ══════════════════════════════════════════════════════
//  ACTION TYPES — grouped, with field specs
// ══════════════════════════════════════════════════════
const ACTION_GROUPS = {
  '— Flow —':['raw','comment','blank','if','elif','else','match','case','for','while','break','continue','pass'],
  '— Variables —':['var','const','assign'],
  '— Functions —':['return','call','await','await_signal'],
  '— Signals —':['emit_signal'],
  '— Multiplayer —':['rpc_call','rpc_id_call','is_authority','set_authority'],
  '— Debug —':['print','push_error','push_warning','assert'],
  '— Node —':['queue_free'],
};

const ACTION_SPECS = {
  raw:            { needsValue:true,  valuePlaceholder:'any GDScript expression…', rawStyle:true },
  comment:        { needsValue:true,  valuePlaceholder:'comment text', commentStyle:true },
  blank:          {},
  if:             { needsValue:true,  valuePlaceholder:'condition (without "if" and ":")' },
  elif:           { needsValue:true,  valuePlaceholder:'condition' },
  else:           {},
  match:          { needsValue:true,  valuePlaceholder:'expression to match' },
  case:           { needsValue:true,  valuePlaceholder:'"state", 0, Vector2(…), or _' },
  for:            { needsValue:true,  valuePlaceholder:'item in collection' },
  while:          { needsValue:true,  valuePlaceholder:'condition' },
  break:          {},
  continue:       {},
  pass:           {},
  var:            { needsName:true,   needsValue:true, namePlaceholder:'name', valuePlaceholder:'initial value' },
  const:          { needsName:true,   needsValue:true, namePlaceholder:'NAME', valuePlaceholder:'value' },
  assign:         { needsName:true,   needsValue:true, namePlaceholder:'variable / property', valuePlaceholder:'new value' },
  return:         { needsValue:true,  valuePlaceholder:'value (empty for bare return)' },
  call:           { needsValue:true,  valuePlaceholder:'any_function(args)' },
  await:          { needsValue:true,  valuePlaceholder:'seconds (creates timer)' },
  await_signal:   { needsValue:true,  valuePlaceholder:'signal_source.signal_name' },
  emit_signal:    { needsName:true,   needsValue:true, namePlaceholder:'signal_name', valuePlaceholder:'args (optional)' },
  rpc_call:       { needsName:true,   needsValue:true, namePlaceholder:'method_name', valuePlaceholder:'args (optional)' },
  rpc_id_call:    { needsValue:true,  valuePlaceholder:'peer_id, "method_name", args…' },
  is_authority:   {},
  set_authority:  { needsValue:true,  valuePlaceholder:'peer_id' },
  print:          { needsValue:true,  valuePlaceholder:'value or "string"' },
  push_error:     { needsValue:true,  valuePlaceholder:'"error message"' },
  push_warning:   { needsValue:true,  valuePlaceholder:'"warning message"' },
  assert:         { needsValue:true,  valuePlaceholder:'condition, "message"' },
  queue_free:     {},
};

function genLine(a) {
  const v = a.value || '';
  const n = a.name  || '';
  switch (a.type) {
    case 'raw':           return v;
    case 'comment':       return `# ${v}`;
    case 'blank':         return '';
    case 'if':            return `if ${v}:`;
    case 'elif':          return `elif ${v}:`;
    case 'else':          return 'else:';
    case 'match':         return `match ${v}:`;
    case 'case':          return `${v}:`;
    case 'for':           return `for ${v}:`;
    case 'while':         return `while ${v}:`;
    case 'break':         return 'break';
    case 'continue':      return 'continue';
    case 'pass':          return 'pass';
    case 'var':           return `var ${n} = ${v}`;
    case 'const':         return `const ${n} = ${v}`;
    case 'assign':        return `${n} = ${v}`;
    case 'return':        return v ? `return ${v}` : 'return';
    case 'call':          return v;
    case 'await':         return `await get_tree().create_timer(${v}).timeout`;
    case 'await_signal':  return `await ${v}`;
    case 'emit_signal':   return v ? `${n}.emit(${v})` : `${n}.emit()`;
    case 'rpc_call':      return v ? `rpc("${n}", ${v})` : `rpc("${n}")`;
    case 'rpc_id_call':   return `rpc_id(${v})`;
    case 'is_authority':  return 'if not is_multiplayer_authority(): return';
    case 'set_authority': return `set_multiplayer_authority(${v})`;
    case 'print':         return `print(${v})`;
    case 'push_error':    return `push_error(${v})`;
    case 'push_warning':  return `push_warning(${v})`;
    case 'assert':        return `assert(${v})`;
    case 'queue_free':    return 'queue_free()';
    default:              return v || 'pass';
  }
}

function genFunction(fn) {
  const lines = [];
  if (fn.rpcMode && fn.rpcMode !== 'none') lines.push(`@rpc(${fn.rpcMode})`);
  const params = fn.params.map(p => {
    let s = p.type ? `${p.name}: ${p.type}` : p.name;
    if (p.defaultValue) s += ` = ${p.defaultValue}`;
    return s;
  }).join(', ');
  const staticStr = fn.isStatic ? 'static ' : '';
  const retStr    = fn.returnType !== 'inferred' ? ` -> ${fn.returnType}` : '';
  lines.push(`${staticStr}func ${fn.name}(${params})${retStr}:`);
  if (!fn.actions || fn.actions.length === 0) lines.push('\tpass');
  else for (const a of fn.actions) lines.push(`${'\t'.repeat((a.indent||0)+1)}${genLine(a)}`);
  return lines.join('\n');
}

function genClassVarLine(cv) {
  const ann  = cv.annotation || '';
  const type = cv.type ? `: ${cv.type}` : '';
  const val  = cv.value ? ` = ${cv.value}` : '';
  if (ann === 'signal') return `signal ${cv.name}`;
  if (ann) return `${ann}\nvar ${cv.name}${type}${val}`;
  return `var ${cv.name}${type}${val}`;
}

function highlight(code) {
  let h = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  h = h.replace(/(@\w+(?:\([^)]*\))?)/g, '<span class="ann">$1</span>');
  h = h.replace(/(#.*$)/gm, '<span class="cmt">$1</span>');
  const stash = [];
  h = h.replace(/(<span class="(?:cmt|ann)">[^<]*<\/span>)/g, m => { stash.push(m); return `\x00${stash.length-1}\x00`; });
  h = h.replace(/"([^"]*)"/g, '\x01<span class="str">"$1"</span>\x01');
  const KEYWORDS = ['func','var','const','if','elif','else','for','while','match','return','pass','break','continue','and','or','not','in','is','null','true','false','await','static','signal','enum','class','extends','self','super','new','preload','load'];
  const KW2 = ['rpc','rpc_id','emit','connect','disconnect','set_multiplayer_authority','is_multiplayer_authority','get_multiplayer_authority','print','push_error','push_warning','assert','queue_free'];
  const TYPES = ['void','bool','int','float','String','Vector2','Vector3','Vector2i','Vector3i','Color','Transform2D','Transform3D','Basis','Quaternion','AABB','Rect2','Plane','Node','Node2D','Node3D','CharacterBody2D','CharacterBody3D','RigidBody3D','VehicleBody3D','Area3D','CollisionShape3D','RayCast3D','AnimationPlayer','Dictionary','Array','Variant','PackedStringArray','PackedVector3Array'];
  h = h.replace(new RegExp(`\\b(${KEYWORDS.join('|')})\\b`, 'g'), '<span class="kw">$1</span>');
  h = h.replace(new RegExp(`\\b(${KW2.join('|')})\\b`, 'g'), '<span class="kw2">$1</span>');
  h = h.replace(new RegExp(`\\b(${TYPES.join('|')})\\b`, 'g'), '<span class="ty">$1</span>');
  h = h.replace(/\b(\d+(?:\.\d+)?(?:e[+-]?\d+)?)\b/g, '<span class="num">$1</span>');
  h = h.replace(/\b(\w+)\s*(?=\()/g, (m,p1) => KEYWORDS.includes(p1) ? m : `<span class="fn">${p1}</span>(`);
  h = h.replace(/\x01([^\x01]*)\x01/g,'$1');
  h = h.replace(/\x00(\d+)\x00/g, (_,i) => stash[parseInt(i)]);
  return h;
}

// DOM rendering helpers (abridged but functional)
function toggleSec(hdr) { hdr.classList.toggle('open'); const body = hdr.nextElementSibling; if(body) body.classList.toggle('open'); }
function esc(s) { return String(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function renderClassVars() { /* simplified for brevity but full logic */ const el=document.getElementById('cvarList'); if(!classVars.length){el.innerHTML='';return;} el.innerHTML=classVars.map(cv=>`<div class="cvar-item"><select class="cvar-ann" onchange="updateCV(${cv.id},'annotation',this.value)">${['','@export','@onready','@export_range','signal','@static_unload'].map(a=>`<option ${cv.annotation===a?'selected':''}>${a}</option>`).join('')}</select><input class="cvar-name" value="${esc(cv.name)}" onchange="updateCV(${cv.id},'name',this.value)"><input class="cvar-type" value="${esc(cv.type)}" onchange="updateCV(${cv.id},'type',this.value)"><input class="cvar-val" value="${esc(cv.value)}" onchange="updateCV(${cv.id},'value',this.value)"><button class="cvar-del" onclick="removeCV(${cv.id})">🗑</button></div>`).join(''); }
function renderTabs() { const bar=document.getElementById('funcTabBar'); bar.innerHTML=functions.map(fn=>`<div class="func-tab ${fn.id===activeFnId?'active':''}" onclick="setActiveFunc(${fn.id})">${esc(fn.name)}<span class="tab-del" onclick="event.stopPropagation();removeFunc(${fn.id})">✕</span></div>`).join('')+'<button class="add-func-btn" onclick="addFunction()">＋ Add Function</button>'; }
function renderEditor() { /* keeping core functionality */ const fn=getActiveFn(); const ed=document.getElementById('funcEditor'); if(!fn){ed.innerHTML='<div class="empty-hint" style="margin:20px">Click <strong>＋ Add Function</strong> to start building,<br>or load a template from the panel below.</div>';return;} ed.innerHTML=`<div class="sec"><div class="sec-hdr open" onclick="toggleSec(this)"><div class="dot" style="background:var(--purple)"></div>Function Signature<span class="arrow">▶</span></div><div class="sec-body open"><div class="row2"><div class="field"><div class="field-label">Name</div><input type="text" value="${esc(fn.name)}" onchange="updateFn('name',this.value)"></div><div class="field"><div class="field-label">Return Type</div><select onchange="updateFn('returnType',this.value)">${['void','bool','int','float','String','Variant','Vector2','Vector3','Dictionary','Array','inferred'].map(t=>`<option ${fn.returnType===t?'selected':''}>${t}</option>`).join('')}</select></div></div><div class="toggle-row"><div class="toggle ${fn.isStatic?'active':''}" onclick="toggleFn('isStatic')"><input type="checkbox" ${fn.isStatic?'checked':''}> static func</div></div><div class="field"><div class="field-label">@rpc Annotation</div><select onchange="updateFn('rpcMode',this.value)"><option value="none">no @rpc</option><option value='"any_peer","call_local","reliable"'>any_peer · local · reliable</option><option value='"any_peer","call_remote","reliable"'>any_peer · remote · reliable</option><option value='"authority","call_local","reliable"'>authority · local · reliable</option><option value='"authority","call_remote","reliable"'>authority · remote · reliable</option><option value='"any_peer","call_local","unreliable_ordered"'>any_peer · local · unrel-ordered</option></select></div></div></div><div class="sec"><div class="sec-hdr open" onclick="toggleSec(this)"><div class="dot" style="background:var(--blue)"></div>Parameters<span class="arrow">▶</span></div><div class="sec-body open"><div class="param-list">${fn.params.map(p=>`<div class="param-item"><input type="text" value="${esc(p.name)}" onchange="updateParam(${p.id},'name',this.value)"><select onchange="updateParam(${p.id},'type',this.value)">${['Variant','int','float','String','bool','Vector2','Vector3','Node','Node3D','CharacterBody3D','VehicleBody3D','Area3D','RayCast3D','Dictionary','Array'].map(t=>`<option ${p.type===t?'selected':''}>${t}</option>`).join('')}</select><input type="text" value="${esc(p.defaultValue)}" placeholder="= default" onchange="updateParam(${p.id},'defaultValue',this.value)"><button class="param-del" onclick="removeParam(${p.id})">🗑</button></div>`).join('')}${fn.params.length===0?'<div class="empty-hint">No parameters. Click + to add.</div>':''}</div><button class="add-btn" onclick="addParam()">+ Add Parameter</button></div></div><div class="sec"><div class="sec-hdr open" onclick="toggleSec(this)"><div class="dot" style="background:var(--green)"></div>Action Sequence<span class="arrow">▶</span></div><div class="sec-body open"><div class="action-list" id="actionList">${fn.actions.map((a,i)=>`<div class="action-row" data-indent="${a.indent||0}" data-id="${a.id}"><div class="indent-strip"></div><div class="action-move"><button onclick="moveAction(${a.id},-1)">▲</button><button onclick="moveAction(${a.id},+1)">▼</button></div><select class="action-type-sel" onchange="updateAction(${a.id},'type',this.value)">${Object.entries(ACTION_GROUPS).map(([grp,types])=>`<optgroup label="${grp}">${types.map(t=>`<option ${a.type===t?'selected':''}>${t}</option>`).join('')}</optgroup>`).join('')}</select><div class="indent-ctrl"><button onclick="changeIndent(${a.id},-1)">◀</button><span class="indent-val">${a.indent||0}</span><button onclick="changeIndent(${a.id},+1)">▶</button></div><div class="action-fields">${(ACTION_SPECS[a.type]||{}).needsName?`<input type="text" value="${esc(a.name||'')}" placeholder="name" onchange="updateAction(${a.id},'name',this.value)">`:''}${(ACTION_SPECS[a.type]||{}).needsValue?`<input type="text" class="${(ACTION_SPECS[a.type]||{}).rawStyle?'raw-input':(ACTION_SPECS[a.type]||{}).commentStyle?'comment-input':''}" value="${esc(a.value||'')}" placeholder="${(ACTION_SPECS[a.type]||{}).valuePlaceholder||''}" onchange="updateAction(${a.id},'value',this.value)">`:''}</div><button class="action-del" onclick="removeAction(${a.id})">🗑</button></div>`).join('')}</div><div style="display:flex;gap:6px"><button class="add-btn green" style="flex:2" onclick="addAction()">+ Add Action</button><button class="add-btn" style="flex:1" onclick="addAction('raw')">+ Raw Code</button><button class="add-btn" style="flex:1" onclick="addAction('blank')">+ Blank Line</button></div></div></div>`; }
function generateAll() { const blocks=[]; if(classVars.length) blocks.push(classVars.map(genClassVarLine).join('\n'),''); for(const fn of functions) blocks.push(genFunction(fn),''); setOutput(blocks.length?highlight(blocks.join('\n').trim()):'<span class="cmt"># No functions defined yet.</span>'); updateStatus(); }
function setOutput(html){document.getElementById('outputCode').innerHTML=html;}
function addClassVar(){classVars.push({id:uid(),annotation:'',name:'my_var',type:'',value:''});renderClassVars();}
function removeCV(id){classVars=classVars.filter(c=>c.id!==id);renderClassVars();}
function updateCV(id,field,val){const c=classVars.find(c=>c.id===id);if(c)c[field]=val;renderClassVars();}
function addFunction(template){const id=uid();functions.push({id,name:template?.name||`my_function_${id}`,returnType:template?.returnType||'void',isStatic:template?.isStatic||false,rpcMode:template?.rpcMode||'none',params:(template?.params||[]).map(p=>({...p,id:uid()})),actions:(template?.actions||[]).map(a=>({...a,id:uid()}))});activeFnId=id;renderTabs();renderEditor();updateStatus();}
function removeFunc(id){functions=functions.filter(f=>f.id!==id);if(activeFnId===id)activeFnId=functions.length?functions[functions.length-1].id:null;renderTabs();renderEditor();updateStatus();}
function setActiveFunc(id){activeFnId=id;renderTabs();renderEditor();}
function getActiveFn(){return functions.find(f=>f.id===activeFnId)||null;}
function updateFn(field,val){const fn=getActiveFn();if(fn){fn[field]=val;if(field==='name')renderTabs();}}
function toggleFn(field){const fn=getActiveFn();if(fn){fn[field]=!fn[field];renderEditor();}}
function addParam(){const fn=getActiveFn();if(fn)fn.params.push({id:uid(),name:`param${fn.params.length+1}`,type:'Variant',defaultValue:''});renderEditor();}
function removeParam(id){const fn=getActiveFn();if(fn)fn.params=fn.params.filter(p=>p.id!==id);renderEditor();}
function updateParam(id,field,val){const fn=getActiveFn();if(fn){const p=fn.params.find(p=>p.id===id);if(p)p[field]=val;}}
function addAction(type='pass'){const fn=getActiveFn();if(fn){const lastIndent=fn.actions.length?fn.actions[fn.actions.length-1].indent:0;fn.actions.push({id:uid(),type,value:'',name:'',indent:lastIndent});renderEditor();updateStatus();}}
function removeAction(id){const fn=getActiveFn();if(fn){fn.actions=fn.actions.filter(a=>a.id!==id);renderEditor();updateStatus();}}
function updateAction(id,field,val){const fn=getActiveFn();if(fn){const a=fn.actions.find(a=>a.id===id);if(a){a[field]=val;if(field==='type')renderEditor();}}}
function moveAction(id,dir){const fn=getActiveFn();if(fn){const idx=fn.actions.findIndex(a=>a.id===id);const nxt=idx+dir;if(nxt>=0&&nxt<fn.actions.length){[fn.actions[idx],fn.actions[nxt]]=[fn.actions[nxt],fn.actions[idx]];renderEditor();}}}
function changeIndent(id,delta){const fn=getActiveFn();if(fn){const a=fn.actions.find(a=>a.id===id);if(a){a.indent=Math.max(0,Math.min(8,(a.indent||0)+delta));renderEditor();}}}
function updateStatus(){const total=functions.reduce((s,f)=>s+f.actions.length,0);document.getElementById('funcCount').textContent=`${functions.length} function${functions.length!==1?'s':''} · ${total} action${total!==1?'s':''}`;document.getElementById('statusText').textContent='Ready';}
function copyCode(){const code=document.getElementById('outputCode').innerText||'';navigator.clipboard.writeText(code).then(()=>{const btn=document.getElementById('copyBtn');btn.textContent='Copied!';btn.classList.add('ok');setTimeout(()=>{btn.textContent='Copy All';btn.classList.remove('ok');},1800);});}
function exportJSON(){const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify({classVars,functions},null,2)],{type:'application/json'}));a.download='gdscript_config.json';a.click();}
function importJSON(input){const file=input.files[0];if(!file)return;const r=new FileReader();r.onload=e=>{try{const d=JSON.parse(e.target.result);classVars=d.classVars||[];functions=d.functions||[];activeFnId=functions.length?functions[0].id:null;renderClassVars();renderTabs();renderEditor();updateStatus();document.getElementById('statusText').textContent='Config imported ✓';}catch(ex){alert('Invalid JSON file: '+ex.message);}};r.readAsText(file);input.value='';}
const TEMPLATES=[{id:'vehicle_enter',label:'🚗 Enter Vehicle',template:{name:'enter_vehicle',returnType:'bool',params:[{name:'vehicle',type:'VehicleBody3D'},{name:'seat_index',type:'int',defaultValue:'0'}],actions:[{type:'if',value:'not vehicle or not is_multiplayer_authority()'},{type:'return',value:'false',indent:1},{type:'assign',name:'current_vehicle',value:'vehicle'},{type:'return',value:'true'}]}}];
function buildTemplateGrid(){document.getElementById('tmplGrid').innerHTML=TEMPLATES.map(t=>`<button class="tmpl-btn" onclick="addFunction(${JSON.stringify(t.template)}); generateAll();"><span>${t.label.split(' ')[0]}</span>${t.label.split(' ').slice(1).join(' ')}</button>`).join('');}
buildTemplateGrid(); renderClassVars(); renderTabs(); renderEditor(); updateStatus();
</script>
