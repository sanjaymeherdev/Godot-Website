<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Build with Sanjay · AI & Automation Training</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>

  <!-- Header -->
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo">Build<span>.</span>with<span style="color:#2563eb;">Sanjay</span></div>
      <nav class="nav-links">
        <a href="index.html">Home</a>
        <a href="android.html">Android</a>
        <a href="windows.html">Windows</a>
        <a href="webapps.html">Web Apps</a>
        <a href="websites.html">Websites</a>
        <a href="infrastructure.html">Infrastructure</a>
        <a href="pricing.html">Pricing</a>
        <a href="contact.html" class="btn btn-outline" style="padding:6px 18px;">Contact</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero container">
    <h1>Learn AI the way <i>it matters to you</i></h1>
    <p class="sub">Pick your platform — Android, Windows, or Web — and build a real, working product you own. Live training, not pre-recorded fluff.</p>
    <div class="proof-badge">
      <span><i class="fas fa-code"></i> 20+ tools built</span>
      <span><i class="fas fa-mobile-alt"></i> 4 Android apps</span>
      <span><i class="fas fa-cloud"></i> Self-hosted infra</span>
      <span><i class="fas fa-rocket"></i> 3-year journey</span>
    </div>
  </section>

  <!-- Modules Grid -->
  <section id="modules" class="container">
    <h2 class="section-title">Choose your path</h2>
    <p class="section-sub">Each module is a complete project — you'll ship a real product, not a demo. Pick one, or take all and build a unified system.</p>
    <div class="modules-grid">
      <!-- Android -->
      <div class="module-card">
        <div class="icon"><i class="fab fa-android"></i></div>
        <h3>Android</h3>
        <div class="price">₹8,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle"></i> PocketAI (floating AI overlay)</li>
          <li><i class="fas fa-check-circle"></i> CGLive (streaming + PiP)</li>
          <li><i class="fas fa-check-circle"></i> AdMob / Unity Ads (earn)</li>
          <li><i class="fas fa-check-circle"></i> Multi-WebView, libraries</li>
        </ul>
        <a href="android.html" class="btn">Learn More →</a>
      </div>
      <!-- Windows -->
      <div class="module-card">
        <div class="icon"><i class="fab fa-windows"></i></div>
        <h3>Windows</h3>
        <div class="price">₹5,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle"></i> Desktop AI agent (local)</li>
          <li><i class="fas fa-check-circle"></i> 3 approaches: Godot, Node.js, Electron</li>
          <li><i class="fas fa-check-circle"></i> Web → desktop port</li>
          <li><i class="fas fa-check-circle"></i> Chrome extension (bonus)</li>
        </ul>
        <a href="windows.html" class="btn">Learn More →</a>
      </div>
      <!-- Web Apps -->
      <div class="module-card">
        <div class="icon"><i class="fas fa-layer-group"></i></div>
        <h3>Web Apps</h3>
        <div class="price">₹7,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle"></i> Self-host n8n (Zapier alternative)</li>
          <li><i class="fas fa-check-circle"></i> AI chat site (SaaS)</li>
          <li><i class="fas fa-check-circle"></i> HR app, Calendly alternative</li>
          <li><i class="fas fa-check-circle"></i> Custom dashboards for clients</li>
        </ul>
        <a href="webapps.html" class="btn">Learn More →</a>
      </div>
      <!-- Websites -->
      <div class="module-card">
        <div class="icon"><i class="fas fa-globe"></i></div>
        <h3>Websites</h3>
        <div class="price">₹6,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle"></i> Portfolio (client-getting)</li>
          <li><i class="fas fa-check-circle"></i> Ecom store with DB</li>
          <li><i class="fas fa-check-circle"></i> Flipbook, wedding cards</li>
          <li><i class="fas fa-check-circle"></i> AI chatbot integration</li>
        </ul>
        <a href="websites.html" class="btn">Learn More →</a>
      </div>
      <!-- Infrastructure -->
      <div class="module-card">
        <div class="icon"><i class="fas fa-server"></i></div>
        <h3>Infrastructure</h3>
        <div class="price">₹15,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle"></i> Render, Railway, Vercel, Netlify</li>
          <li><i class="fas fa-check-circle"></i> Supabase (DB, auth, edge, cron)</li>
          <li><i class="fas fa-check-circle"></i> Neon, Upstash, Cloudflare</li>
          <li><i class="fas fa-check-circle"></i> Meta, Google, AI APIs</li>
        </ul>
        <a href="infrastructure.html" class="btn">Learn More →</a>
      </div>
      <!-- Bundle -->
      <div class="module-card bundle-highlight">
        <div class="icon" style="color:#facc15;"><i class="fas fa-cubes"></i></div>
        <h3>All Modules</h3>
        <div class="price">₹25,000 <small>one-time</small></div>
        <ul>
          <li><i class="fas fa-check-circle" style="color:#facc15;"></i> Everything above</li>
          <li><i class="fas fa-check-circle" style="color:#facc15;"></i> <strong>Unified backend</strong></li>
          <li><i class="fas fa-check-circle" style="color:#facc15;"></i> Cross-app communication</li>
          <li><i class="fas fa-check-circle" style="color:#facc15;"></i> Shared auth, DB, APIs</li>
        </ul>
        <a href="pricing.html" class="btn">View Bundle →</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
            <div id="sanjay-footer"></div>
   <script src="js/components.js"></script>

  <script src="js/main.js"></script>
</body>
</html>
